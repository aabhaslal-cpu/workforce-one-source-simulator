# Local development only. Production and preview must set non-development credentials.
SIMULATOR_RUNTIME_ENV=development
SIMULATOR_ADMIN_API_KEY=dev-admin-key

# Server-side credential-to-connection binding. The key is the credential, the value is the only connection ID it may access.
# If omitted in local development, the app generates documented per-connection credentials of the form:
# dev-connection-secret:<connectionId>
SIMULATOR_CONNECTION_CREDENTIALS=
SIMULATOR_REVOKED_CONNECTION_CREDENTIALS=

# Durable local storage defaults to SQLite. Memory storage requires SIMULATOR_STORAGE_DRIVER=memory and SIMULATOR_ALLOW_EPHEMERAL_MEMORY=true.
SIMULATOR_STORAGE_DRIVER=sqlite
SIMULATOR_SQLITE_PATH=.simulator/source-simulator.sqlite
SIMULATOR_ALLOW_EPHEMERAL_MEMORY=false
DATABASE_URL=

SIMULATOR_PUBLIC_BASE_URL=http://localhost:3000
SIMULATOR_DEFAULT_SEED=wfo-m1-seed
SIMULATOR_DEFAULT_DATASET_SIZE=small
