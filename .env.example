# Local development only. Production and preview must set non-development credentials.
SIMULATOR_RUNTIME_ENV=development
SIMULATOR_ADMIN_API_KEY=dev-admin-key

# Server-side credential-to-connection binding. The key is the credential, the value is the only connection ID it may access.
# If omitted in local development, the app generates documented per-connection credentials of the form:
# dev-connection-secret:<connectionId>
SIMULATOR_CONNECTION_CREDENTIALS=
SIMULATOR_REVOKED_CONNECTION_CREDENTIALS=

# Durable local storage defaults to SQLite. Production/preview must use Postgres.
# Memory storage requires SIMULATOR_STORAGE_DRIVER=memory and SIMULATOR_ALLOW_EPHEMERAL_MEMORY=true.
SIMULATOR_STORAGE_DRIVER=sqlite
SIMULATOR_SQLITE_PATH=.simulator/source-simulator.sqlite
SIMULATOR_ALLOW_EPHEMERAL_MEMORY=false
# Production example: postgres://user:password@host:5432/source_simulator
DATABASE_URL=
# Benchmarks must use a separate Postgres URL. The service rejects reuse of DATABASE_URL.
SIMULATOR_BENCHMARK_DATABASE_URL=

SIMULATOR_PUBLIC_BASE_URL=http://localhost:3000
SIMULATOR_DEFAULT_SEED=wfo-m1-seed
SIMULATOR_DEFAULT_DATASET_SIZE=small

# Persisted company clock. Production/Vercel should use realtime with continuous activity enabled.
SIMULATOR_CLOCK_MODE=manual
SIMULATOR_CLOCK_SPEED=30
SIMULATOR_CONTINUOUS_ACTIVITY=false
SIMULATOR_MAX_CATCH_UP_SECONDS=21600
SIMULATOR_FEED_MAX_CATCH_UP_SECONDS=300
CRON_SECRET=

# Optional deterministic failure simulation. Disabled by default.
# Example:
# SIMULATOR_FAILURE_MODES={"schemaVersion":"failure-modes.v1","rules":[{"id":"rate-limit-feed","enabled":true,"mode":"rate_limit","operation":"feed","connectionId":"conn-product-manager"}]}
SIMULATOR_FAILURE_MODES=

# Real service rate limits. Preview/production force Postgres-backed distributed enforcement.
# Example:
# SIMULATOR_RATE_LIMITS={"enabled":true,"windowMs":60000,"adminLimit":600,"connectionLimit":600,"cronLimit":120}
SIMULATOR_RATE_LIMITS=
SIMULATOR_RATE_LIMIT_ENABLED=

# Set to true to emit one sanitized JSON log line per request.
SIMULATOR_STRUCTURED_LOGS=false

# Node server graceful shutdown grace period in milliseconds.
SIMULATOR_SHUTDOWN_GRACE_MS=10000

# CI-only Postgres parity test URL. The GitHub workflow provides this automatically.
SIMULATOR_POSTGRES_TEST_URL=
