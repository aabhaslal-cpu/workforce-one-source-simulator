{
  "name": "workforce-one-source-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x",
    "pnpm": "9.15.9"
  },
  "scripts": {
    "dev": "tsx src/local-server.ts",
    "start": "node dist/local-server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "vercel:validate": "node scripts/validate-vercel-config.mjs",
    "vercel:build": "npx -y vercel@39.2.5 build --yes",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run lint && pnpm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.16",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
